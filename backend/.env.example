# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Frontend URL (for CORS)
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Optional: Error monitoring
SENTRY_DSN=

# Optional: Email (Resend — https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@skolar.in

# App settings
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# Trust-first runtime controls (recommended for production)
TRUST_STRICT_P1=true
TRUST_CANARY_PERCENT=5
TRUST_AUTOPOLICY_REPEAT_THRESHOLD=3
TRUST_AUTOPOLICY_P1_IMPROVEMENT_MIN=0.2
TRUST_DUAL_RUN_ENABLED=true
TRUST_DUAL_RUN_PERCENT=5
TRUST_DUAL_RUN_TIMEOUT_MS=45000
